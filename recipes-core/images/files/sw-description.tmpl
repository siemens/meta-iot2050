software =
{
    version = "0.1";
    name = "fat-edge iot2050 update image"
    images: ({
            filename = "${ROOTFS_PARTITION_NAME}";
            device = "/dev/mmcblk0p1,/dev/mmcblk0p2";
            type = "roundrobin";
            compressed = "zlib";
            filesystem = "ext4";
    });
}
