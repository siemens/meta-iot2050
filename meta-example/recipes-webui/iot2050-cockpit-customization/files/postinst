#!/bin/sh

set -e

systemctl daemon-reload >/dev/null 2>&1 || true

if [ "$1" = "configure" ] || [ "$1" = "abort-upgrade" ] || \
   [ "$1" = "abort-deconfigure" ] || [ "$1" = "abort-remove" ]; then
	deb-systemd-helper unmask 'iot2050-board-marker.service' >/dev/null || true

	if deb-systemd-helper --quiet was-enabled 'iot2050-board-marker.service'; then
		deb-systemd-helper enable 'iot2050-board-marker.service' >/dev/null || true
	else
		deb-systemd-helper update-state 'iot2050-board-marker.service' >/dev/null || true
	fi
fi

# Run once immediately so the console banner appears without waiting for
# a reboot or a NetworkManager interface change.
/usr/lib/iot2050/cockpit/update-issue >/dev/null 2>&1 || true
