diff --git a/lib/rsa/rsa-sign.c b/lib/rsa/rsa-sign.c
index fa9e143..150b910 100644
--- a/lib/rsa/rsa-sign.c
+++ b/lib/rsa/rsa-sign.c
@@ -20,6 +20,7 @@
 #include <openssl/ssl.h>
 #include <openssl/evp.h>
 #include <openssl/engine.h>
+#include <openssl/store.h>
 
 static int rsa_err(const char *msg)
 {
@@ -300,15 +301,61 @@ static int rsa_engine_get_priv_key(const char *keydir, const char *name,
  * @keydir:	Directory containing the key (PEM file) or key prefix (engine)
  * @name	Name of key
  * @engine	Engine to use for signing
+ * @propquery Property query to use for signing
  * @evpp	Returns EVP_PKEY object, or NULL on failure
  * Return: 0 if ok, -ve on error (in which case *evpp will be set to NULL)
  */
+/* The provider must implement the OSSL_OP_STORE API */
+static int rsa_get_priv_key_property_query(const char *keyfile,
+					   const char *propquery,
+					   EVP_PKEY **evpp)
+{
+	OSSL_STORE_INFO *store_info = NULL;
+	OSSL_STORE_CTX *store_ctx = NULL;
+	int ret = -EINVAL;
+
+	store_ctx = OSSL_STORE_open_ex(keyfile, NULL, propquery, NULL, NULL,
+				       NULL, NULL, NULL);
+	if (!store_ctx) {
+		fprintf(stderr, "Could not open %s with propquery %s\n", keyfile,
+			propquery);
+		goto out;
+	}
+
+	if (OSSL_STORE_expect(store_ctx, OSSL_STORE_INFO_PKEY) != 1) {
+		fprintf(stderr, "Private key does not exist in %s\n", keyfile);
+		goto out;
+	}
+
+	store_info = OSSL_STORE_load(store_ctx);
+	if (!store_info) {
+		fprintf(stderr, "Could not load private key from %s\n", keyfile);
+		goto out;
+	}
+
+	*evpp = OSSL_STORE_INFO_get1_PKEY(store_info);
+	if (!*evpp)
+		fprintf(stderr, "Could not construct EVP_PKEY from %s!\n", keyfile);
+	else
+		ret = 0;
+
+out:
+	if (store_info)
+		OSSL_STORE_INFO_free(store_info);
+	if (store_ctx)
+		OSSL_STORE_close(store_ctx);
+	return ret;
+}
+
 static int rsa_get_priv_key(const char *keydir, const char *name,
-			    const char *keyfile, ENGINE *engine, EVP_PKEY **evpp)
+			    const char *keyfile, ENGINE *engine,
+			    const char *propquery, EVP_PKEY **evpp)
 {
 	if (engine)
 		return rsa_engine_get_priv_key(keydir, name, keyfile, engine,
 					       evpp);
+	else if (propquery)
+		return rsa_get_priv_key_property_query(keyfile, propquery, evpp);
 	return rsa_pem_get_priv_key(keydir, name, keyfile, evpp);
 }
 
