diff --git a/tools/iot2050-sign-fw.sh b/tools/iot2050-sign-fw.sh
index 75ffd56..82b4bbc 100755
--- a/tools/iot2050-sign-fw.sh
+++ b/tools/iot2050-sign-fw.sh
@@ -1,15 +1,51 @@
 #!/bin/sh
 
-if [ -z "$1" ]; then
-	echo "Usage: $0 KEY"
+set -e
+
+PROVIDER_NAME=""
+PROPQUERY=""
+KEY=""
+REVISION=""
+
+usage() {
+	echo "Usage: $0 [--provider PROVIDER_NAME] [--propquery Q] KEY [REVISION]"
 	exit 1
+}
+
+while [ "$#" -gt 0 ]; do
+case "$1" in
+	--provider)
+		PROVIDER_NAME="$2"
+		shift 2
+		;;
+	--propquery)
+		PROPQUERY="$2"
+		shift 2
+		;;
+	-*)
+		echo "Unknown option: $1"
+		usage
+		;;
+	*)
+		if [ -z "$KEY" ]; then
+			KEY="$1"
+		else
+			REVISION="$1"
+		fi
+		shift
+		;;
+esac
+done
+
+if [ -z "$KEY" ]; then
+	usage
 fi
 
 TOOLS_DIR=$(dirname $0)
 
 TEMP_X509=$(mktemp XXXXXXXX.temp)
 
-REVISION=${2:-0}
+REVISION=${REVISION:-0}
 SHA_VAL=$(openssl dgst -sha512 -hex tispl.bin | sed -e "s/^.*= //g")
 BIN_SIZE=$(stat -c %s tispl.bin)
 
@@ -39,12 +75,23 @@ EOF
 
 CERT_X509=$(mktemp XXXXXXXX.crt)
 
-openssl req -new -x509 -key $1 -nodes -outform DER -out $CERT_X509 -config $TEMP_X509 -sha512
-cat $CERT_X509 tispl.bin > tispl.bin_signed
-$TOOLS_DIR/binman/binman replace -i flash-pg1.bin -f tispl.bin_signed fit@180000
-$TOOLS_DIR/binman/binman replace -i flash-pg2.bin -f tispl.bin_signed fit@180000
+if [ -n "$PROVIDER_NAME" ]; then
+	PROVIDER_PARA="-provider $PROVIDER_NAME"
+fi
+
+openssl req -new -x509 $PROVIDER_PARA -key "$KEY" -noenc -outform DER \
+	-out "$CERT_X509" -config "$TEMP_X509" -sha512
+cat "$CERT_X509" tispl.bin > tispl.bin_signed
+"$TOOLS_DIR"/binman/binman replace -i flash-pg1.bin -f tispl.bin_signed fit@180000
+"$TOOLS_DIR"/binman/binman replace -i flash-pg2.bin -f tispl.bin_signed fit@180000
 
-rm $TEMP_X509 $CERT_X509
+rm "$TEMP_X509" "$CERT_X509"
+
+if [ -n "$PROPQUERY" ]; then
+	PROPQUERY_PARA="-p $PROPQUERY"
+fi
 
-$TOOLS_DIR/binman/binman sign -i flash-pg1.bin -k $1 -a sha256,rsa4096 fit@380000
-$TOOLS_DIR/binman/binman sign -i flash-pg2.bin -k $1 -a sha256,rsa4096 fit@380000
+$TOOLS_DIR/binman/binman sign -i flash-pg1.bin -k "$KEY" -a sha256,rsa4096 \
+	$PROPQUERY_PARA fit@380000
+$TOOLS_DIR/binman/binman sign -i flash-pg2.bin -k "$KEY" -a sha256,rsa4096 \
+	$PROPQUERY_PARA fit@380000
