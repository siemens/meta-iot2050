From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Li Hua Qian <huaqian.li@siemens.com>
Date: Wed, 22 Jul 2026 16:19:06 +0800
Subject: [PATCH] tools: fdtgrep: Preserve SPL DTB padding

The SPL control DTB is rebuilt by fdtgrep after dtc generates the
source DTB. This rebuild discards padding added by dtc -p, leaving no
space for later SPL fixups even when CONFIG_SYS_DTC_PAD_BYTES is set.

Add --pad-bytes to fdtgrep and pass the configured value when generating
the SPL control DTB. This preserves writable tail space after the SPL
pruning pass.

Signed-off-by: Li Hua Qian <huaqian.li@siemens.com>
---
 scripts/Makefile.lib |  1 +
 tools/fdtgrep.c      | 22 +++++++++++++++++++---
 2 files changed, 20 insertions(+), 3 deletions(-)

diff --git a/scripts/Makefile.lib b/scripts/Makefile.lib
index d66f1ed13b13..6a7247eff7c2 100644
--- a/scripts/Makefile.lib
+++ b/scripts/Makefile.lib
@@ -697,6 +697,7 @@ quiet_cmd_fdtgrep = FDTGREP $@
       cmd_fdtgrep = $(objtree)/tools/fdtgrep $(fdtgrep_props) -u -RT $< \
 		-n /chosen -n /config -O dtb | \
 	$(objtree)/tools/fdtgrep -r -O dtb - -o $@ \
+		--pad-bytes $(CONFIG_SYS_DTC_PAD_BYTES) \
 		-P bootph-all -P bootph-pre-ram -P bootph-pre-sram \
 		-P bootph-verify -P bootph-some-ram \
 		$(migrate_all) \
diff --git a/tools/fdtgrep.c b/tools/fdtgrep.c
index b4c041070f56..76c1927012d7 100644
--- a/tools/fdtgrep.c
+++ b/tools/fdtgrep.c
@@ -47,6 +47,7 @@ enum output_t {
 /* Holds information which controls our output and options */
 struct display_info {
 	enum output_t output;	/* Output format */
+	int pad; /* Pad DTB output by this many bytes */
 	int add_aliases;	/* Add aliases node to output */
 	int all;		/* Display all properties/nodes */
 	int colour;		/* Display output in ANSI colour */
@@ -879,7 +880,7 @@ static int do_fdtgrep(struct display_info *disp, const char *filename)
 		/* Allow reserved memory section to expand slightly */
 		int size = fdt_totalsize(blob) + 16;
 
-		fdt = malloc(size);
+		fdt = malloc(size + disp->pad);
 		if (!fdt) {
 			fprintf(stderr, "Out_of_memory\n");
 			ret = -1;
@@ -889,7 +890,7 @@ static int do_fdtgrep(struct display_info *disp, const char *filename)
 		if (disp->remove_strings) {
 			void *out;
 
-			out = malloc(size);
+			out = malloc(size + disp->pad);
 			if (!out) {
 				fprintf(stderr, "Out_of_memory\n");
 				ret = -1;
@@ -913,6 +914,16 @@ static int do_fdtgrep(struct display_info *disp, const char *filename)
 			size = fdt_totalsize(fdt);
 		}
 
+		if (disp->pad) {
+			ret = fdt_open_into(fdt, fdt, size + disp->pad);
+			if (ret < 0) {
+				fprintf(stderr, "Failed to pad output: err=%d\n",
+					ret);
+				goto err;
+			}
+			size = fdt_totalsize(fdt);
+		}
+
 		if ((size_t)size != fwrite(fdt, 1, size, disp->fout)) {
 			fprintf(stderr, "Write failure, %d bytes\n", size);
 			free(fdt);
@@ -965,7 +976,7 @@ static const char usage_synopsis[] =
 	case '?': usage("unknown option");
 
 static const char usage_short_opts[] =
-		"haAc:b:C:defg:G:HIlLmn:N:o:O:p:P:rRsStTuv"
+		"haAc:b:C:defg:G:HIlLmn:N:o:O:p:P:rRsStTuvZ:"
 		USAGE_COMMON_SHORT_OPTS;
 static const struct option usage_long_opts[] = {
 	{"show-address",	no_argument, NULL, 'a'},
@@ -997,6 +1008,7 @@ static const struct option usage_long_opts[] = {
 	{"show-aliases",	no_argument, NULL, 'T'},
 	{"props-up-to-supernode", no_argument, NULL, 'u'},
 	{"invert-match",	no_argument, NULL, 'v'},
+	{"pad-bytes",		a_argument, NULL, 'Z'},
 	USAGE_COMMON_LONG_OPTS,
 };
 static const char * const usage_opts_help[] = {
@@ -1029,6 +1041,7 @@ static const char * const usage_opts_help[] = {
 	"Include matching aliases in output",
 	"Add -p properties to supernodes too",
 	"Invert the sense of matching (select non-matching lines)",
+	"Pad DTB output by <arg> bytes",
 	USAGE_COMMON_OPTS_HELP
 };
 
@@ -1220,6 +1233,9 @@ static void scan_args(struct display_info *disp, int argc, char *argv[])
 		case 'v':
 			disp->invert = 1;
 			break;
+		case 'Z':
+			disp->pad = strtoul(optarg, NULL, 0);
+			break;
 		}
 
 		if (type && value_add(disp, &disp->value_head, type, inc,
