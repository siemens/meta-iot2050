 ...-iot2050-arduino-connector-pg2-rework.dtsi | 84 +++++++++++++++++++
 .../dts/ti/k3-am6548-iot2050-advanced-m2.dts  |  1 +
 .../dts/ti/k3-am6548-iot2050-advanced-pg2.dts |  1 +
 3 files changed, 86 insertions(+)
 create mode 100644 arch/arm64/boot/dts/ti/k3-am65-iot2050-arduino-connector-pg2-rework.dtsi

diff --git a/arch/arm64/boot/dts/ti/k3-am65-iot2050-arduino-connector-pg2-rework.dtsi b/arch/arm64/boot/dts/ti/k3-am65-iot2050-arduino-connector-pg2-rework.dtsi
new file mode 100644
index 000000000000..860001bbcded
--- /dev/null
+++ b/arch/arm64/boot/dts/ti/k3-am65-iot2050-arduino-connector-pg2-rework.dtsi
@@ -0,0 +1,84 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Copyright (c) Siemens AG, 2025
+ *
+ * Authors:
+ *   Jan Kiszka <jan.kiszka@siemens.com>
+ *
+ * Arduino connector rework for IOT2050 Advanced PG2 variants (M2/PG2)
+ *
+ * - WKUP_GPIO0_34, WKUP_GPIO0_41 → not connected
+ * - WKUP_GPIO0_36 → D4200 (pcal9535_1) INT
+ * - WKUP_GPIO0_37 → D4201 (pcal9535_2) INT
+ * - WKUP_GPIO0_38 → D4202 (pcal9535_3) INT
+ * - IO14-direction through IO18-direction moved from WKUP_GPIO0 to PCA9535
+ *
+ * Include AFTER k3-am65-iot2050-arduino-connector.dtsi
+ */
+
+#include <dt-bindings/interrupt-controller/irq.h>
+
+&wkup_pmx0 {
+	arduino_io_oe_pins_default: arduino-io-oe-default-pins {
+		pinctrl-single,pins = <
+			/* (M2) WKUP_GPIO0_36 → D4200 INT */
+			AM65X_WKUP_IOPAD(0x0060, PIN_INPUT, 7)
+			/* (M3) WKUP_GPIO0_37 → D4201 INT */
+			AM65X_WKUP_IOPAD(0x0064, PIN_INPUT, 7)
+			/* (M4) WKUP_GPIO0_38 → D4202 INT */
+			AM65X_WKUP_IOPAD(0x0068, PIN_INPUT, 7)
+		>;
+	};
+};
+
+&wkup_gpio0 {
+	gpio-line-names =
+		/* 0..9 */
+		"wkup_gpio0-base", "", "", "", "UART0-mode1", "UART0-mode0",
+		"UART0-enable", "UART0-terminate", "", "WIFI-disable",
+		/* 10..19 */
+		"", "", "", "", "", "", "", "", "", "",
+		/* 20..29 */
+		"", "A4A5-I2C-mux", "", "", "", "USER-button", "", "", "", "IO0",
+		/* 30..39 */
+		"IO1", "IO2", "", "IO3", "", "A5",
+		"D4200-INT", "D4201-INT", "D4202-INT", "A3",
+		/* 40..49 */
+		"", "", "A4", "A2", "A1", "A0", "", "", "IO13",
+		"IO11",
+		/* 50..51 */
+		"IO12", "IO10";
+};
+
+/* 所有的dirpin要配置为output低，防止SoC侧的干扰 */
+
+&pcal9535_1 {
+	interrupt-parent = <&wkup_gpio0>;
+	interrupts = <36 IRQ_TYPE_EDGE_FALLING>;
+	gpio-line-names =
+		"A0-pull", "A1-pull", "A2-pull", "A3-pull", "A4-pull",
+		"A5-pull",
+		"IO14-direction",
+		"IO15-direction",
+		"IO14-enable", "IO15-enable", "IO16-enable",
+		"IO17-enable", "IO18-enable", "IO19-enable",
+		"IO18-direction",
+		"IO16-direction";
+};
+
+&pcal9535_2 {
+	interrupt-parent = <&wkup_gpio0>;
+	interrupts = <37 IRQ_TYPE_EDGE_FALLING>;
+};
+
+&pcal9535_3 {
+	interrupt-parent = <&wkup_gpio0>;
+	interrupts = <38 IRQ_TYPE_EDGE_FALLING>;
+	gpio-line-names =
+		"IO0-pull", "IO1-pull", "IO2-pull", "IO3-pull",
+		"IO4-pull", "IO5-pull", "IO6-pull", "IO7-pull",
+		"IO8-pull", "IO9-pull", "IO10-pull", "IO11-pull",
+		"IO12-pull", "IO13-pull",
+		"IO17-direction",
+		"";
+};
diff --git a/arch/arm64/boot/dts/ti/k3-am6548-iot2050-advanced-m2.dts b/arch/arm64/boot/dts/ti/k3-am6548-iot2050-advanced-m2.dts
